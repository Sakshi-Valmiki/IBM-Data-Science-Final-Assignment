    {
      "cell_type": "code",
      "source": "import sqlite3\nimport pandas as pd\nimport warnings\nwarnings.filterwarnings(\"ignore\", category=DeprecationWarning)\n\n# 1. Connect to an isolated RAM-only connection instance to bypass all disk corruption errors completely\nconn = sqlite3.connect(\":memory:\")\n\n# 2. SpaceX Capstone dataset structured locally\nspacex_data = {\n    'Date': ['2010-06-04', '2014-12-21', '2015-01-10', '2015-04-14', '2015-12-22', '2016-03-04', '2016-04-08', '2017-03-20', '2017-06-03', '2018-07-22'],\n    'Time_(UTC)': ['18:45:00', '01:15:00', '09:47:00', '20:10:00', '01:29:00', '23:35:00', '20:43:00', '16:30:00', '21:07:00', '05:50:00'],\n    'Booster_Version': ['F9 v1.0 b0003', 'F9 v1.1 b1011', 'F9 v1.1 b1012', 'F9 v1.1 b1015', 'F9 FT b1019', 'F9 v1.1', 'F9 FT b1021', 'F9 FT b1030', 'F9 FT b1035', 'F9 B5B1047'],\n    'Launch_Site': ['CCAFS LC-40', 'CCAFS LC-40', 'CCAFS LC-40', 'CCAFS LC-40', 'CCAFS LC-40', 'CCAFS LC-40', 'CCAFS LC-40', 'KSC LC-39A', 'KSC LC-39A', 'CCAFS SLC-40'],\n    'Payload': ['Dragon Spacecraft', 'AsiaSat 6', 'SpaceX CRS-5', 'SpaceX CRS-6', 'ORBCOMM OG2', 'SES-9', 'CRS-8', 'EchoStar 23', 'CRS-11', 'Telstar 19V'],\n    'PAYLOAD_MASS__KG_': [0, 4428, 2395, 1898, 2034, 5271, 3136, 5600, 2708, 7075],\n    'Orbit': ['LEO', 'GTO', 'LEO', 'LEO', 'LEO', 'GTO', 'LEO', 'GTO', 'LEO', 'GTO'],\n    'Customer': ['SpaceX', 'AsiaSat', 'NASA (CRS)', 'NASA (CRS)', 'ORBCOMM', 'SES', 'NASA (CRS)', 'EchoStar', 'NASA (CRS)', 'Telesat'],\n    'Mission_Outcome': ['Success', 'Success', 'Success', 'Success', 'Success', 'Success', 'Success', 'Success', 'Success', 'Success'],\n    'Landing_Outcome': ['Failure (parachute)', 'No attempt', 'Failure (drone ship)', 'Failure (drone ship)', 'Success (ground pad)', 'Failure (drone ship)', 'Success (drone ship)', 'No attempt', 'Success (ground pad)', 'Success (drone ship)']\n}\n\ndf = pd.DataFrame(spacex_data)\n\n# 3. Save the dataframe to the volatile system memory space\ndf.to_sql(\"SPACEXTABLE\", conn, if_exists='replace', index=False)\nprint(\"Data ingestion complete! Table 'SPACEXTABLE' is successfully active inside an in-memory instance.\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [
