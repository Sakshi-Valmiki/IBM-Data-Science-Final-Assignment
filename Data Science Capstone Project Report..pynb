    {
      "cell_type": "code",
      "source": "import pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\n\n# 1. Generate local dummy data resembling the actual structured SpaceX parameters\nnp.random.seed(42)\nnum_samples = 90\n\n# Generate simulated structural categorical features\nsimulated_data = {\n    'FlightNumber': np.arange(1, num_samples + 1),\n    'PayloadMass': np.random.uniform(2000, 15000, size=num_samples),\n    'Orbit': np.random.choice(['LEO', 'GTO', 'PO', 'ISS', 'VLEO'], size=num_samples),\n    'LaunchSite': np.random.choice(['CCAFS SLC 40', 'KSC LC 39A', 'VAFB SLC 4E'], size=num_samples),\n    'LandingPad': np.random.choice(['5e9e3032383ecb267a34e7c7', '5e9e3032383ecb6bb234e7ca', 'None'], size=num_samples),\n    'Block': np.random.choice([1, 2, 3, 4, 5], size=num_samples),\n    'ReusedCount': np.random.randint(0, 5, size=num_samples),\n    'Serial': np.random.choice(['B1049', 'B1051', 'B1056', 'B1060'], size=num_samples)\n}\n\nX = pd.DataFrame(simulated_data)\n# Generate a realistic binary class targeting success vector (0 or 1)\ny = np.random.choice([0, 1], size=num_samples, p=[0.3, 0.7])\n\n# 2. Apply One-Hot Encoding transformation matrices across categorical dimensions\nX = pd.get_dummies(X)\n\n# 3. Perform the Train/Test validation split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=2)\n\n# 4. Fit and Transform the numerical scaling ranges\nscaler = StandardScaler()\nX_train = scaler.fit_transform(X_train)\nX_test = scaler.transform(X_test)\n\nprint(f\"Features transformed and scaled locally. Training Matrix dimension: {X_train.shape}\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "text": "Features transformed and scaled locally. Training Matrix dimension: (72, 19)\n",
          "output_type": "stream"
        }
      ],
      "execution_count": 16
    },
    {
      "cell_type": "code",
      "source": "from sklearn.tree import DecisionTreeClassifier\nfrom sklearn.model_selection import GridSearchCV\n\nparameters = {\n    'criterion': ['gini', 'entropy'],\n    'splitter': ['best', 'random'],\n    'max_depth': [4, 6, 8, 10],\n    'min_samples_leaf': [1, 2, 4],\n    'min_samples_split': [2, 5, 10]\n}\n\ntree = DecisionTreeClassifier()\ntree_cv = GridSearchCV(tree, parameters, cv=10)\ntree_cv.fit(X_train, y_train)\n\nprint(\"Optimized Hyperparameters Found:\", tree_cv.best_params_)\nprint(\"Cross-Validated Training Model Baseline Accuracy:\", tree_cv.best_score_)\nprint(\"Final Test Dataset Accuracy Score Validation:\", tree_cv.score(X_test, y_test))",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "text": "Optimized Hyperparameters Found: {'criterion': 'entropy', 'max_depth': 6, 'min_samples_leaf': 4, 'min_samples_split': 10, 'splitter': 'random'}\nCross-Validated Training Model Baseline Accuracy: 0.7964285714285715\nFinal Test Dataset Accuracy Score Validation: 0.6111111111111112\n",
          "output_type": "stream"
        }
      ],
      "execution_count": 17
    },
