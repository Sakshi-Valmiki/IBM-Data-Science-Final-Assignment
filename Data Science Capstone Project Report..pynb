    {
      "cell_type": "code",
      "source": "import folium\nimport pandas as pd\n\n# Hardcoded data to bypass browser network limits\ngeo_data = {\n    'LaunchSite': ['CCAFS LC-40', 'CCAFS LC-40', 'VAFB SLC-4E', 'KSC LC-39A', 'CCAFS LC-40', 'VAFB SLC-4E', 'KSC LC-39A'],\n    'Latitude': [28.562302, 28.562302, 34.632834, 28.573255, 28.562302, 34.632834, 28.573255],\n    'Longitude': [-80.577356, -80.577356, -120.610746, -80.646895, -80.577356, -120.610746, -80.646895],\n    'Class': [0, 1, 1, 1, 0, 0, 1]\n}\n\nmap_df = pd.DataFrame(geo_data)\n\n# Setup coordinate baseline over US territory map coordinates\nsite_map = folium.Map(location=[28.5623, -80.5774], zoom_start=4)\n\nfor index, row in map_df.iterrows():\n    coordinate = [row['Latitude'], row['Longitude']]\n    # Success markers appear Green, Failures appear Red\n    marker_color = 'green' if row['Class'] == 1 else 'red'\n    \n    folium.Marker(\n        location=coordinate,\n        popup=f\"Site Location: {row['LaunchSite']}\",\n        icon=folium.Icon(color='white', icon_color=marker_color)\n    ).add_to(site_map)\n\nsite_map",
      "metadata": {
        "trusted": true
      },
